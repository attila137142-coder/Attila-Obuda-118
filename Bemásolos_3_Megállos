<!DOCTYPE html>
<html lang="hu">
<head>
<meta charset="UTF-8">
<title>BKK PRO Menetrend</title>

<style>
body{background:black;color:yellow;text-align:center;font-family:Arial;}
#lista{color:cyan;font-size:18px;}
button{padding:10px;margin:5px;font-size:16px;}

.piros{color:red;}
.kek{color:#00ffff;}
.normal{color:white;}
</style>
</head>

<body>

<h1>🚌 BKK PRO Menetrend</h1>

<button onclick="kozeli()">📍 Közeli megállók</button>

<div id="lista">Adatok...</div>

<script>

let sajatPoz=null;

// GPS
navigator.geolocation.watchPosition(p=>{
  sajatPoz=[p.coords.latitude,p.coords.longitude];
});

// KÖZELI MEGÁLLÓK
function kozeli(){

 fetch(`https://overpass-api.de/api/interpreter?data=
 [out:json];
 node(around:800,${sajatPoz[0]},${sajatPoz[1]})
 ["highway"="bus_stop"];
 out;`)

 .then(r=>r.json())
 .then(d=>{

   let lista=d.elements.map(e=>{
     let tav=Math.sqrt(
       (e.lat-sajatPoz[0])**2 +
       (e.lon-sajatPoz[1])**2
     );

     return {nev:e.tags.name||"Megálló", tav};
   });

   lista.sort((a,b)=>a.tav-b.tav);

   megjelenit(lista.slice(0,5));
 });
}

// LISTA
function megjelenit(lista){

 let html="";

 lista.forEach(m=>{
   html+=`<div onclick="menetrend('${m.nev}')">${m.nev}</div>`;
 });

 document.getElementById("lista").innerHTML=html;
}

// MENETREND LOGIKA
function menetrend(nev){

 let now=new Date();
 let html=`<h3>${nev}</h3>`;

 for(let i=1;i<=6;i++){

   let indul=new Date(now.getTime()+i*4*60000);

   // "késés" szimuláció (GTFS helyett)
   let delay=Math.floor(Math.random()*120)-60;

   let szin="normal";
   if(delay>20) szin="kek";
   if(delay<-20) szin="piros";

   html+=`
   <div class="${szin}">
   Járat ${i} →
   ${indul.getHours()}:${String(indul.getMinutes()).padStart(2,'0')}
   (${delay} mp)
   </div>`;
 }

 document.getElementById("lista").innerHTML=html;
}

// AUTO FRISSÍTÉS
setInterval(()=>{
  if(document.getElementById("lista").innerText.includes("Járat")){
    let nev=document.querySelector("h3")?.innerText;
    if(nev) menetrend(nev);
  }
},15000);

</script>
